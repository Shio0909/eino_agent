# ===========================================
# Eino RAG Agent - Docker 环境配置
# ===========================================
# 快速开始:
#   1. cp .env.example .env
#   2. 编辑 .env 填入你的 API Key
#   3. make up (核心服务) 或 make up-full (全部服务)
#
# 服务端口一览:
#   80    - 前端 UI          8080  - 后端 API
#   5432  - PostgreSQL       6379  - Redis
#   50051 - DocReader        8100  - Reranker
#   9000  - MinIO API        9001  - MinIO Console
#   16686 - Jaeger UI

# ===========================================
# Application Settings
# ===========================================
VERSION=latest
APP_PORT=8080
GIN_MODE=release
LOG_LEVEL=info

# ===========================================
# Auth & RBAC
# ===========================================
AUTH_ENABLED=false
# 生产环境启用 AUTH_ENABLED=true 时必须设置强随机值，至少 16 字符
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_TENANT_ID=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
USER_TENANT_ID=1
USER_USERNAME=user
USER_PASSWORD=

# 前端连接后端的地址 (Docker 内部通信, 一般不需要修改)
APP_HOST=app
APP_BACKEND_PORT=8080
APP_SCHEME=http

# ===========================================
# Frontend UI
# ===========================================
FRONTEND_PORT=80

# ===========================================
# Chat Mode (pipeline / agentic)
# ===========================================
CHAT_MODE=pipeline
AGENTIC_RAG_ENABLED=true

# ===========================================
# PostgreSQL Database
# ===========================================
# DBeaver / pgAdmin 连接信息:
#   Host: localhost  Port: 5432
#   Database: eino_rag  User: eino  Password: <your-db-password>
DB_HOST=postgres
DB_PORT=5432
DB_USER=eino
DB_PASSWORD=
DB_NAME=eino_rag
DB_SSLMODE=disable

# ===========================================
# Redis
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# LLM Configuration
# ===========================================
# 支持: OpenAI, DeepSeek, 智谱, Kimi, Ollama 等 OpenAI 兼容 API
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Embedding Configuration
# ===========================================
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# 如需单独配置 Embedding API (不同于 LLM):
# EMBEDDING_API_KEY=sk-your-embedding-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# ===========================================
# Reranker Configuration
# ===========================================
# 使用本地 Reranker 服务 (需要 make up-reranker):
RERANKER_BASE_URL=http://reranker:8100
RERANKER_API_KEY=
# 或使用 Jina Reranker API:
# RERANKER_BASE_URL=https://api.jina.ai/v1
# RERANKER_API_KEY=jina_xxx

# 本地 Reranker 服务设置
RERANKER_PORT=8100
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# ===========================================
# MinIO Object Storage
# ===========================================
# Console: http://localhost:9001
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=eino-minio
MINIO_SECRET_KEY=
MINIO_BUCKET=eino-files

# ===========================================
# DocReader Service
# ===========================================
# 使用 WeKnora DocReader 镜像（Python gRPC 文档解析服务）
DOCREADER_PORT=50051
MAX_FILE_SIZE_MB=50
WEKNORA_VERSION=v0.3.0

# ===========================================
# Ollama (Local LLM)
# ===========================================
# Docker 内部通过 host.docker.internal 访问宿主机 Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ===========================================
# Jaeger Tracing
# ===========================================
# UI: http://localhost:16686
JAEGER_PORT=16686

# ===========================================
# Tavily Web Search (可选)
# ===========================================
TAVILY_API_KEY=your_tavily_api_key_here

# ===========================================
# MCP Server (可选)
# ===========================================
# MCP_SERVER_URL=http://localhost:3001

# ===================================
# 常见第三方 API 配置示例
# ===================================

# --- DeepSeek ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- 智谱 AI (GLM) ---
# OPENAI_API_KEY=xxx
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_MODEL=glm-4-flash

# --- 月之暗面 (Kimi) ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# --- 本地 Ollama ---
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2

# --- 硅基流动 (SiliconFlow) ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
