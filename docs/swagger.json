{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "基于字节跳动 Eino 框架的智能知识库问答系统。支持 Pipeline 和 Agentic 两种问答模式。",
        "title": "Eino RAG Agent API",
        "contact": {
            "name": "Eino RAG Agent"
        },
        "license": {
            "name": "Apache 2.0"
        },
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/chat": {
            "post": {
                "description": "发送消息并获取 AI 回答，支持 Pipeline 和 Agentic 两种模式",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "聊天"
                ],
                "summary": "聊天问答",
                "parameters": [
                    {
                        "description": "聊天请求",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.ChatRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.ChatResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/chat/stream": {
            "post": {
                "description": "发送消息并通过 Server-Sent Events 获取流式 AI 回答",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "聊天"
                ],
                "summary": "流式聊天 (SSE)",
                "parameters": [
                    {
                        "description": "聊天请求",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.ChatRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE 流",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "检查服务及各组件状态",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/knowledge-bases": {
            "get": {
                "description": "获取当前租户下所有知识库",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "知识库列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "description": "创建新的知识库",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "创建知识库",
                "parameters": [
                    {
                        "description": "知识库信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.KnowledgeBaseRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/repository.KnowledgeBase"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/knowledge-bases/{id}": {
            "get": {
                "description": "获取指定知识库的详细信息",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "知识库详情",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/repository.KnowledgeBase"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "put": {
                "description": "更新知识库信息",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "更新知识库",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "更新信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.KnowledgeBaseRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "delete": {
                "description": "删除指定知识库及其所有文档",
                "tags": [
                    "知识库"
                ],
                "summary": "删除知识库",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/knowledge-bases/{id}/documents": {
            "get": {
                "description": "获取知识库下的文档列表",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "文档列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "description": "上传文档到指定知识库，自动解析、分块、向量化",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "上传文档",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "文档文件",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/knowledge-bases/{id}/documents/url": {
            "post": {
                "description": "从指定 URL 抓取内容到知识库，自动解析、分块、向量化",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "知识库"
                ],
                "summary": "上传网页 URL",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "URL 导入请求",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "enable_multimodal": {
                                    "type": "boolean"
                                },
                                "title": {
                                    "type": "string"
                                },
                                "url": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/knowledge-bases/{id}/documents/{docId}": {
            "delete": {
                "description": "删除知识库中的指定文档",
                "tags": [
                    "知识库"
                ],
                "summary": "删除文档",
                "parameters": [
                    {
                        "type": "string",
                        "description": "知识库 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "文档 ID",
                        "name": "docId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/models": {
            "get": {
                "description": "获取所有已配置的 AI 模型（LLM、Embedding、Reranker）",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "模型"
                ],
                "summary": "模型列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "description": "添加新的模型配置",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "模型"
                ],
                "summary": "创建模型",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/models/{id}": {
            "delete": {
                "description": "删除指定模型配置",
                "tags": [
                    "模型"
                ],
                "summary": "删除模型",
                "parameters": [
                    {
                        "type": "string",
                        "description": "模型 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/sessions": {
            "get": {
                "description": "获取所有聊天会话",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "会话"
                ],
                "summary": "会话列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "description": "创建新的聊天会话",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "会话"
                ],
                "summary": "创建会话",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/repository.Session"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/sessions/{id}": {
            "get": {
                "description": "获取指定会话的详细信息",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "会话"
                ],
                "summary": "会话详情",
                "parameters": [
                    {
                        "type": "string",
                        "description": "会话 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/repository.Session"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "delete": {
                "description": "删除指定聊天会话",
                "tags": [
                    "会话"
                ],
                "summary": "删除会话",
                "parameters": [
                    {
                        "type": "string",
                        "description": "会话 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/sessions/{id}/messages": {
            "get": {
                "description": "获取指定会话的所有消息记录",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "会话"
                ],
                "summary": "会话消息列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "会话 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/settings": {
            "get": {
                "description": "获取系统配置信息（RAG参数、Agent 配置等）",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "设置"
                ],
                "summary": "获取设置",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "put": {
                "description": "运行时更新系统配置（RAG、Agent、Agentic RAG）",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "设置"
                ],
                "summary": "更新设置",
                "parameters": [
                    {
                        "description": "要更新的设置",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.SettingsUpdateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/system/info": {
            "get": {
                "description": "获取系统版本、组件状态等信息",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "系统信息",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.AgentSettingsUpdate": {
            "type": "object",
            "properties": {
                "enable_knowledge_tool": {
                    "type": "boolean"
                },
                "enable_web_search": {
                    "type": "boolean"
                },
                "enabled": {
                    "type": "boolean"
                },
                "max_steps": {
                    "type": "integer"
                }
            }
        },
        "handler.AgenticRAGSettingsUpdate": {
            "type": "object",
            "properties": {
                "enable_web_fallback": {
                    "type": "boolean"
                },
                "enabled": {
                    "type": "boolean"
                },
                "max_retries": {
                    "type": "integer"
                },
                "max_run_steps": {
                    "type": "integer"
                },
                "quality_threshold": {
                    "type": "number"
                }
            }
        },
        "handler.ChatRequest": {
            "type": "object",
            "properties": {
                "document_ids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "enable_long_term": {
                    "type": "boolean"
                },
                "force_citation": {
                    "type": "boolean"
                },
                "knowledge_base_ids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "message": {
                    "type": "string"
                },
                "mode": {
                    "type": "string"
                },
                "query": {
                    "type": "string"
                },
                "session_id": {
                    "type": "string"
                },
                "temperature": {
                    "type": "number"
                },
                "top_k": {
                    "type": "integer"
                },
                "use_agent": {
                    "type": "boolean"
                }
            }
        },
        "handler.ChatResponse": {
            "type": "object",
            "properties": {
                "answer": {
                    "type": "string"
                },
                "latency_ms": {
                    "type": "integer"
                },
                "references": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handler.ReferenceDocument"
                    }
                },
                "session_id": {
                    "type": "string"
                },
                "tokens_used": {
                    "type": "integer"
                }
            }
        },
        "handler.EmbeddingSettingsUpdate": {
            "type": "object",
            "properties": {
                "api_key": {
                    "type": "string"
                },
                "base_url": {
                    "type": "string"
                },
                "model": {
                    "type": "string"
                },
                "provider": {
                    "type": "string"
                }
            }
        },
        "handler.GraphRAGSettingsUpdate": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "extract_temperature": {
                    "type": "number"
                },
                "max_depth": {
                    "type": "integer"
                },
                "top_k": {
                    "type": "integer"
                }
            }
        },
        "handler.KnowledgeBaseRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "chunking_config": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "description": {
                    "type": "string"
                },
                "embedding_dimensions": {
                    "type": "integer"
                },
                "embedding_model_id": {
                    "type": "string"
                },
                "extract_config": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "handler.LLMSettingsUpdate": {
            "type": "object",
            "properties": {
                "api_key": {
                    "type": "string"
                },
                "base_url": {
                    "type": "string"
                },
                "max_tokens": {
                    "type": "integer"
                },
                "model": {
                    "type": "string"
                },
                "provider": {
                    "type": "string"
                },
                "temperature": {
                    "type": "number"
                }
            }
        },
        "handler.RAGSettingsUpdate": {
            "type": "object",
            "properties": {
                "chunk_overlap": {
                    "type": "integer"
                },
                "chunk_size": {
                    "type": "integer"
                },
                "enable_hybrid": {
                    "type": "boolean"
                },
                "enable_rerank": {
                    "type": "boolean"
                },
                "enable_rewrite": {
                    "type": "boolean"
                },
                "top_k": {
                    "type": "integer"
                }
            }
        },
        "handler.ReferenceDocument": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                },
                "score": {
                    "type": "number"
                },
                "source": {
                    "type": "string"
                }
            }
        },
        "handler.RerankerSettingsUpdate": {
            "type": "object",
            "properties": {
                "api_key": {
                    "type": "string"
                },
                "base_url": {
                    "type": "string"
                },
                "enabled": {
                    "type": "boolean"
                },
                "model": {
                    "type": "string"
                },
                "provider": {
                    "type": "string"
                },
                "threshold": {
                    "type": "number"
                },
                "top_k": {
                    "type": "integer"
                }
            }
        },
        "handler.SettingsUpdateRequest": {
            "type": "object",
            "properties": {
                "agent": {
                    "$ref": "#/definitions/handler.AgentSettingsUpdate"
